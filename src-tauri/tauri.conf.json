{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quick-note",
  "version": "0.1.0",
  "identifier": "com.rans.quick-note",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Quick Note",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "txt"
        ],
        "name": "Text Document",
        "description": "Plain text file",
        "role": "Editor",
        "mimeType": "text/plain"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "quick-note.desktop"
      }
    }
  }
}